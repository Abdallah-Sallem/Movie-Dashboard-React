# Copy this file to `.env` and replace the placeholder with your TMDB API key.
# Example:
# VITE_TMDB_API_KEY=abc123yourkey

VITE_TMDB_API_KEY=

# Notes:
# - Leave this blank if you don't have a TMDB key; the app will use a local fallback dataset.
# - Do NOT commit your real `.env` containing secrets.